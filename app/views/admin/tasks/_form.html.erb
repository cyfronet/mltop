<%# locals: (task:) %>

<%= form_with(model: task, url: [:admin, task], class: "contents") do |form| %>
  <div class="space-y-12">
    <div class="mt-10 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
      <%= form.text_field :name, wrapper: "sm:col-span-4" %>
      <%= form.text_field :slug, wrapper: "sm:col-span-2" %>
      <%= form.text_area :info, wrapper: "col-span-full", class: "h-32" %>
      <%= form.rich_text_area :description, wrapper: "col-span-full", class: "h-96" %>
      <%= form.select :from, Task::TYPES, include_blank: false, wrapper: "sm:col-span-1" %>
      <%= form.select :to, Task::TYPES, include_blank: false, wrapper: "sm:col-span-1" %>
      <%= form.collection_select :evaluator_ids, Evaluator.all, :id, :name, multiple: true, wrapper: "sm:col-span-2" %>
    </div>
  </div>

  <ul>
    <%= form.fields_for :test_set_tasks do |tsts_form| %>
      <li>
        <%= tsts_form.rich_text_area :description, label: {text:"Description for #{tsts_form.object.test_set.name}" }, value: tsts_form.object.description%>
      </li>
    <% end%>
  </ul>

  <div class="mt-6 mb-2 flex items-center justify-end gap-x-6">
    <%= link_to "Cancel", [:admin, task], class: "btn btn-secondary-outline" %>
    <%= form.submit %>
  </div>
<% end %>
