<% content_for :head do %>
  <%= turbo_refreshes_with method: :morph, scroll: :preserve %>
<% end %>

<% breadcrumb :task, @task %>

<%= mltop_title @task.name %>

<%= render "menu", task: @task %>

<%= @task.description %>

<% @test_set_tasks.each do |test_set_task| %>
  <h2 class="mt-2 text-2xl font-bold tracking-tight sm:text-4xl mb-8 mt-8 text-center">
    <%= link_to "#{test_set_task.test_set.name} test set", test_set_path(test_set_task.test_set) %>
  </h2>

  <%= render "test_sets/show", test_set: test_set_task.test_set, test_set_tasks: [test_set_task] %>
<% end %>



