<%# locals: (consent:) %>

<%= turbo_frame_tag consent do %>
  <div class="sm:flex sm:items-start sm:justify-between">
    <span><%= consent.description %></span>
    <span><%= consent.target %></span>
    <span><%= consent.required %></span>
    <div class="mt-5 sm:ml-6 sm:mt-0 sm:flex sm:shrink-0 sm:items-center space-x-2">
      <%= link_to edit_consent_path(consent), class: "btn btn-secondary-outline" do %>
        <%= edit_icon("ml-0.5 mr-1.5 h-5 w-5") %>
        <span> Edit </span>
      <% end %>

      <%= button_to consent_path(consent), class: "btn btn-danger", method: :delete,
          form: { "data-turbo-confirm": "Are you sure you want to remove this consent?",
                  "data-turbo-frame": "_top" } do %>
        <%= trash_icon("ml-0.5 mr-1.5 h-5 w-5") %>
        <span> Delete </span>
      <% end %>
    </div>
  </div>
<% end %>

<div class="relative py-3">
  <div class="absolute inset-0 flex items-center" aria-hidden="true">
    <div class="w-full border-t border-gray-300"></div>
  </div>
</div>

